# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GROQ_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PEXELS_API_KEY: Required for searching diagrams & educational illustrations from Pexels.
PEXELS_API_KEY=

# CANVA_CLIENT_ID: Your Canva Connect API Developer Client ID.
CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET: Your Canva Connect API Developer Client Secret.
CANVA_CLIENT_SECRET=
# CANVA_BRAND_TEMPLATE_ID: Optional default Canva brand template ID for diagram generation.
CANVA_BRAND_TEMPLATE_ID=


